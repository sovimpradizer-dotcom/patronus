<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patronus | Marketing Digital & Estratégia</title>
    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;400;600;800&family=Montserrat:wght@700;900&display=swap" rel="stylesheet">
    <!-- Ícones Lucide -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-dark: #050608;
            --bg-grey: #121418;
            --accent-blue: #4a5d7a;
            --accent-glow: rgba(74, 93, 122, 0.15);
            --text-light: #f8f9fa;
            --text-muted: #8a94a1;
            --white: #ffffff;
            --border: rgba(255, 255, 255, 0.08);
            --transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            outline: none;
        }

        /* --- TELA DE CARREGAMENTO (LOADER) --- */
        #loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--bg-dark);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity 0.8s ease, visibility 0.8s;
        }

        #loader.fade-out {
            opacity: 0;
            visibility: hidden;
        }

        .loader-content {
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .loader-logo {
            width: 60px;
            height: 60px;
            stroke: var(--white);
            stroke-width: 1.5;
            fill: none;
            animation: pulseLogo 2s infinite ease-in-out;
        }

        .loader-bar-container {
            width: 150px;
            height: 1px;
            background: rgba(255, 255, 255, 0.1);
            position: relative;
            overflow: hidden;
        }

        .loader-bar {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 0;
            background: var(--white);
            animation: fillBar 3s forwards cubic-bezier(0.65, 0, 0.35, 1);
        }

        @keyframes pulseLogo {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 1; }
        }

        @keyframes fillBar {
            0% { width: 0; }
            100% { width: 100%; }
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* --- BACKGROUND DINÂMICO --- */
        .bg-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 50% 50%, #15181d 0%, #050608 100%);
            z-index: -1;
            overflow: hidden;
        }

        .glow-orb {
            position: absolute;
            width: 600px;
            height: 600px;
            background: var(--accent-glow);
            filter: blur(120px);
            border-radius: 50%;
            z-index: -1;
            animation: floatOrb 20s infinite alternate;
        }

        @keyframes floatOrb {
            0% { transform: translate(-10%, -10%); }
            100% { transform: translate(20%, 30%); }
        }

        .geo-grid {
            position: absolute;
            width: 200%;
            height: 200%;
            background-image: 
                linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            transform: perspective(500px) rotateX(60deg);
            bottom: -50%;
            left: -50%;
            mask-image: linear-gradient(to top, black, transparent);
            opacity: 0.4;
        }

        /* --- TIPOGRAFIA --- */
        h1, h2, h3 {
            font-family: 'Montserrat', sans-serif;
            text-transform: uppercase;
            letter-spacing: 4px;
            font-weight: 900;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .section-padding {
            padding: 140px 0;
        }

        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: var(--transition);
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .btn {
            display: inline-block;
            padding: 16px 40px;
            background: var(--white);
            color: var(--bg-dark);
            text-decoration: none;
            font-weight: 800;
            font-size: 0.8rem;
            letter-spacing: 2px;
            border-radius: 2px;
            transition: var(--transition);
            border: 1px solid var(--white);
            text-transform: uppercase;
            cursor: pointer;
        }

        .btn:hover {
            background: transparent;
            color: var(--white);
            box-shadow: 0 0 20px rgba(255,255,255,0.2);
        }

        /* --- HEADER --- */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            padding: 30px 0;
            transition: var(--transition);
        }

        header.scrolled {
            background: rgba(5, 6, 8, 0.8);
            backdrop-filter: blur(20px);
            padding: 15px 0;
            border-bottom: 1px solid var(--border);
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--white);
            text-decoration: none;
            letter-spacing: 5px;
        }

        .logo svg {
            width: 35px;
            height: 35px;
            stroke: var(--white);
            stroke-width: 1.5;
            transition: var(--transition);
            fill: none;
        }

        .logo:hover svg {
            transform: rotate(15deg) scale(1.1);
        }

        .nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.75rem;
            font-weight: 400;
            transition: var(--transition);
            letter-spacing: 2px;
        }

        .nav-links a:hover {
            color: var(--white);
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
        }

        /* --- HERO --- */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .hero-content h1 {
            font-size: clamp(2.5rem, 10vw, 5rem);
            line-height: 0.9;
            margin-bottom: 30px;
            background: linear-gradient(to bottom, #fff 40%, #555 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-content p {
            font-size: 1rem;
            font-weight: 200;
            color: var(--text-muted);
            max-width: 500px;
            margin: 0 auto 50px;
            letter-spacing: 1px;
        }

        /* --- IMAGENS ESTILIZADAS --- */
        .img-container {
            position: relative;
            overflow: hidden;
            border-radius: 4px;
            background: var(--bg-grey);
        }

        .img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(100%) brightness(0.7);
            transition: var(--transition);
        }

        .img-container:hover img {
            filter: grayscale(0%) brightness(0.9);
            transform: scale(1.05);
        }

        /* --- SERVIÇOS --- */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .service-card {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(10px);
            padding: 30px;
            border: 1px solid var(--border);
            border-radius: 4px;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .service-card .card-image {
            height: 180px;
            margin-bottom: 25px;
            border-radius: 2px;
        }

        .service-card:hover {
            border-color: rgba(255,255,255,0.3);
            background: rgba(255, 255, 255, 0.04);
            transform: translateY(-5px);
        }

        .service-card i {
            color: var(--white);
            margin-bottom: 20px;
            opacity: 0.8;
        }

        .service-card h3 {
            font-size: 0.85rem;
            margin-bottom: 15px;
            letter-spacing: 2px;
        }

        .service-card p {
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 300;
        }

        /* --- TESTEMUNHOS --- */
        .testimonial-slide p {
            font-size: 1.5rem;
            font-weight: 200;
            max-width: 700px;
            margin: 0 auto 30px;
            line-height: 1.4;
        }

        /* --- RODAPÉ --- */
        footer {
            padding: 100px 0 50px;
            border-top: 1px solid var(--border);
        }

        .copyright {
            margin-top: 40px;
            font-size: 0.7rem;
            letter-spacing: 3px;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            .hero-content h1 { font-size: 3.5rem; }
            .section-padding { padding: 80px 0; }
            .about-flex { flex-direction: column; }
        }

        /* Grid de Sobre */
        .about-flex {
            display: flex;
            gap: 60px;
            align-items: center;
        }
    </style>
</head>
