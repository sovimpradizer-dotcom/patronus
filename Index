    <script>
        lucide.createIcons();

        // Lógica do Loader (3 segundos)
        window.addEventListener('load', () => {
            setTimeout(() => {
                const loader = document.getElementById('loader');
                loader.classList.add('fade-out');
                // Inicia as animações de revelação após o loader sair
                setTimeout(reveal, 200);
            }, 3000);
        });

        // Lógica de Scroll do Cabeçalho
        window.addEventListener('scroll', () => {
            const header = document.getElementById('header');
            header.classList.toggle('scrolled', window.scrollY > 50);
        });

        // Lógica de Revelação de Elementos
        const reveal = () => {
            document.querySelectorAll('.reveal').forEach(el => {
                if (el.getBoundingClientRect().top < window.innerHeight - 50) {
                    el.classList.add('active');
                }
            });
        };
        window.addEventListener('scroll', reveal);

        // Lógica do Slider de Testemunhos
        const track = document.getElementById('sliderTrack');
        const dotsContainer = document.getElementById('sliderDots');
        const slides = document.querySelectorAll('.testimonial-slide');
        let current = 0;

        slides.forEach((_, i) => {
            const dot = document.createElement('div');
            dot.className = `dot ${i === 0 ? 'active' : ''}`;
            dot.style.cssText = "width:6px; height:6px; background:rgba(255,255,255,0.1); border-radius:50%; cursor:pointer; transition:0.3s; margin: 0 5px;";
            if(i===0) dot.style.background = "white";
            dot.addEventListener('click', () => {
                current = i;
                update();
            });
            dotsContainer.appendChild(dot);
        });

        function update() {
            track.style.transform = `translateX(-${current * 100}%)`;
            document.querySelectorAll('.dot').forEach((d, i) => {
                d.style.background = i === current ? "white" : "rgba(255,255,255,0.1)";
            });
        }

        setInterval(() => {
            current = (current + 1) % slides.length;
            update();
        }, 6000);
    </script>
